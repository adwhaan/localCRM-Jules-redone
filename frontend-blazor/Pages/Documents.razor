@page "/documents"
@attribute [Authorize]

<MudText Typo="Typo.h4" GutterBottom="true">Documents</MudText>

<MudTable Items="@_items" Hover="true" Breakpoint="Breakpoint.Sm" Loading="@_loading" OnRowClick="@((e) => EditItem(e.Item))" T=" DocumentDto">
    <ToolBarContent>
        <MudSpacer />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CreateNew">New Document</MudButton>
    </ToolBarContent>
    <HeaderContent>
        <MudTh>DocumentRef</MudTh>
        <MudTh>Subject</MudTh>
        <MudTh>DocumentType</MudTh>
        <MudTh>Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="DocumentRef">@context.DocumentRef</MudTd>
        <MudTd DataLabel="Subject">@context.Subject</MudTd>
        <MudTd DataLabel="DocumentType">@context.DocumentType</MudTd>
        <MudTd DataLabel="Actions">
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" OnClick="@(() => EditItem(context))" />
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => DeleteItem(context))" />
        </MudTd>
    </RowTemplate>
</MudTable>

@code {
    private List<DocumentDto> _items = new();
    private bool _loading = true;

    [Inject] ApiService ApiService { get; set; } = default!;
    [Inject] NavigationManager Navigation { get; set; } = default!;
    [Inject] ISnackbar Snackbar { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        try
        {
            _items = await ApiService.GetAsync<DocumentDto>("api/documents");
        }
        catch (Exception ex)
        {
            Snackbar.Add("Error loading Documents: " + ex.Message, Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void CreateNew()
    {
        Navigation.NavigateTo("/documents/new");
    }

    private void EditItem(DocumentDto item)
    {
        // Usually we use an ID here
        var idField = typeof(DocumentDto).GetProperties().FirstOrDefault(p => p.Name.Contains("Id"))?.GetValue(item);
        Navigation.NavigateTo($"/documents/{idField}");
    }

    private async Task DeleteItem(DocumentDto item)
    {
        var idField = typeof(DocumentDto).GetProperties().FirstOrDefault(p => p.Name.Contains("Id"))?.GetValue(item);
        try
        {
            await ApiService.DeleteAsync($"api/documents/{idField}");
            Snackbar.Add("Document deleted", Severity.Success);
            await LoadData();
        }
        catch (Exception ex)
        {
            Snackbar.Add("Error deleting Document: " + ex.Message, Severity.Error);
        }
    }
}
