@page "/contacts/{Id}"
@page "/contacts/new"
@attribute [Authorize]

<MudText Typo="Typo.h4" GutterBottom="true">@(IsNew ? "New Contact" : "Edit Contact")</MudText>

<MudPaper Class="pa-8">
    <EditForm Model="@_contact" OnValidSubmit="HandleSubmit">
        <DataAnnotationsValidator />
        <MudGrid>
            <MudItem xs="12" sm="6">
                <MudTextField Label="First Name" @bind-Value="_contact.FirstName" For="@(() => _contact.FirstName)" Required="true" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField Label="Last Name" @bind-Value="_contact.LastName" For="@(() => _contact.LastName)" Required="true" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField Label="Email" @bind-Value="_contact.Email" For="@(() => _contact.Email)" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.subtitle2">Rating</MudText>
                <MudRating @bind-SelectedValue="_contact.Rating" />
            </MudItem>
            <MudItem xs="12" Class="d-flex justify-end mt-4">
                <MudButton Variant="Variant.Text" OnClick="Cancel" Class="mr-2">Cancel</MudButton>
                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Disabled="@_loading">
                    @if (_loading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    Save
                </MudButton>
            </MudItem>
        </MudGrid>
    </EditForm>
</MudPaper>

@code {
    [Parameter] public string? Id { get; set; }
    private ContactDto _contact = new();
    private bool _loading;
    private bool IsNew => Id == null || Id == "new";

    [Inject] ApiService ApiService { get; set; } = default!;
    [Inject] NavigationManager Navigation { get; set; } = default!;
    [Inject] ISnackbar Snackbar { get; set; } = default!;

    protected override async Task OnParametersSetAsync()
    {
        if (!IsNew && int.TryParse(Id, out var id))
        {
            _loading = true;
            try
            {
                var result = await ApiService.GetByIdAsync<ContactDto>($"api/contacts/{id}");
                if (result != null) _contact = result;
            }
            catch (Exception ex)
            {
                Snackbar.Add("Error loading contact: " + ex.Message, Severity.Error);
            }
            finally
            {
                _loading = false;
            }
        }
    }

    private async Task HandleSubmit()
    {
        _loading = true;
        try
        {
            if (IsNew)
            {
                await ApiService.PostAsync("api/contacts", _contact);
                Snackbar.Add("Contact created", Severity.Success);
            }
            else
            {
                await ApiService.PutAsync($"api/contacts/{_contact.ContactId}", _contact);
                Snackbar.Add("Contact updated", Severity.Success);
            }
            Navigation.NavigateTo("/contacts");
        }
        catch (Exception ex)
        {
            Snackbar.Add("Error saving contact: " + ex.Message, Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/contacts");
    }
}
